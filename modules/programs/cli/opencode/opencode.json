{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["README.md", "~/.config/opencode/RULES.md", "docs/**/*.md", "justfile"],
  "default_agent": "plan",
  "agent": {
    "chat": {
      "color": "success"
    },
    "plan": {
      "color": "primary"
    },
    "build": {
      "color": "secondary"
    },
    "researcher": {
      "color": "accent"
    },
    "refactor": {
      "color": "error"
    }
  }
}
