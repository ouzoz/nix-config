@startuml simulation_classes
skinparam classAttributeIconSize 0
skinparam classBorderColor #2255AA
skinparam classBackgroundColor #EEF4FF
skinparam ArrowColor #444444
skinparam shadowing false
skinparam defaultFontSize 11

abstract class Agent {
  # id_ : AgentId
  # type_ : AgentType
  # position_ : Vec2
  # velocity_ : Vec2
  # speed_ : float
  # vision_range_ : float
  # energy_ : float
  # age_ : int
  # alive_ : bool
  # fitness_ : float
  # kills_ : int
  # food_eaten_ : int
  # distance_traveled_ : float
  --
  + Agent(id, type, pos, speed, vision, energy)
  + {abstract} update(dt: float) : void
  + apply_movement(direction: Vec2, dt: float) : void
  + id() : AgentId
  + type() : AgentType
  + position() : Vec2
  + energy() : float
  + alive() : bool
  + fitness() : float
  + kills() : int
  + distance_traveled() : float
  + set_alive(bool) : void
  + add_energy(float) : void
  + drain_energy(float) : void
  + add_kill() : void
  + add_food() : void
  + increment_age() : void
  + is_dead() : bool
}

class Predator {
  - attack_range_ : float
  --
  + Predator(id, pos, speed, vision, energy, attack_range)
  + update(dt: float) : void
  + attack_range() : float
}

class Prey {
  + Prey(id, pos, speed, vision, energy)
  + update(dt: float) : void
}

class Food <<struct>> {
  + position : Vec2
  + active : bool
}

class SensorInput <<struct>> {
  + nearest_predator_dist : float
  + nearest_predator_angle : float
  + nearest_prey_dist : float
  + nearest_prey_angle : float
  + nearest_food_dist : float
  + nearest_food_angle : float
  + energy_level : float
  + speed_x : float
  + speed_y : float
  + local_predator_density : float
  + local_prey_density : float
  + wall_left : float
  + wall_right : float
  + wall_top : float
  + wall_bottom : float
  + {static} SIZE : int = 15
  --
  + to_vector() : vector<float>
}

class Physics <<static>> {
  + {static} build_sensors(agent, agents, food, grid, food_grid, w, h, max_e, walls) : SensorInput
  + {static} process_attacks(agents, grid, attack_range) : vector<AgentId>
}

class Environment {
  - width_ : int
  - height_ : int
  - boundary_mode_ : BoundaryMode
  - food_ : vector<Food>
  - max_food_ : int
  --
  + Environment(config)
  + width() : int
  + height() : int
  + apply_boundary(pos: Vec2) : Vec2
  + initialize_food(rng, count) : void
  + tick_food(rng, rate) : void
  + try_eat_food(position, range) : bool
  + food() : const vector<Food>&
}

class SpatialGrid {
  - cell_size_ : float
  - cols_ : int
  - rows_ : int
  - cells_ : vector<vector<Entry>>
  --
  + SpatialGrid(w, h, cell_size)
  + clear() : void
  + insert(id: AgentId, pos: Vec2) : void
  + query(pos: Vec2) : vector<AgentId>
  + query_radius(pos: Vec2, radius: float) : vector<AgentId>
}

class SimulationManager {
  - config_ : SimulationConfig
  - rng_ : Random
  - environment_ : Environment
  - grid_ : SpatialGrid
  - food_grid_ : SpatialGrid
  - agents_ : vector<unique_ptr<Agent>>
  - current_tick_ : int
  - alive_predators_ : int
  - alive_prey_ : int
  --
  + SimulationManager(config)
  + initialize() : void
  + tick(dt: float) : void
  + reset() : void
  + current_tick() : int
  + agents() : const vector<...>&
  + environment() : const Environment&
  + alive_predators() : int
  + alive_prey() : int
  + get_sensors(index: size_t) : SensorInput
  + apply_action(index: size_t, dir: Vec2, dt: float) : void
}

enum AgentType {
  Predator
  Prey
}

Agent <|-- Predator
Agent <|-- Prey
SimulationManager *-- Environment
SimulationManager *-- "2" SpatialGrid
SimulationManager o-- Agent
Environment *-- Food

@enduml
