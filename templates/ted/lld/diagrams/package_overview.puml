@startuml package_overview
skinparam packageStyle rectangle
skinparam ArrowColor #444444
skinparam PackageBorderColor #2255AA
skinparam PackageBackgroundColor #EEF4FF
skinparam shadowing false
skinparam defaultFontSize 13

package "moonai.core" as core {
  [Vec2\nSimulationConfig\nRandom\nCLIArgs]
}

package "moonai.simulation" as sim {
  [Agent / Predator / Prey\nEnvironment / SpatialGrid\nPhysics / SimulationManager]
}

package "moonai.evolution" as evo {
  [Genome / NeuralNetwork\nSpecies / InnovationTracker\nMutation / Crossover\nEvolutionManager]
}

package "moonai.visualization" as viz {
  [VisualizationManager\nRenderer / UIOverlay]
}

package "moonai.data" as data {
  [Logger\nMetricsCollector]
}

package "moonai.gpu" as gpu {
  [GpuBatch\nGpuNetDesc / GpuNetworkData]
}

sim  -down-> core  : <<use>>
evo  -down-> core  : <<use>>
evo  -down-> sim   : <<use>>
viz  -down-> core  : <<use>>
viz  -down-> sim   : <<use>>
viz  -down-> evo   : <<use>>
data -down-> core  : <<use>>
data -down-> sim   : <<use>>
data -down-> evo   : <<use>>
gpu  -down-> core  : <<use>>

@enduml
