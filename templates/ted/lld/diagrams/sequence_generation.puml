@startuml sequence_generation
skinparam sequenceArrowThickness 1.5
skinparam ParticipantBorderColor #2255AA
skinparam ParticipantBackgroundColor #EEF4FF
skinparam ArrowColor #444444
skinparam shadowing false
skinparam defaultFontSize 11

participant "main.cpp" as main
participant "EvolutionManager" as evo
participant "SimulationManager" as sim
participant "NeuralNetwork[i]" as nn
participant "Logger" as log
participant "GpuBatch\n(optional)" as gpu

== Initialization ==
main -> evo : initialize(num_inputs=15, num_outputs=2)
evo -> evo : build minimal genomes (predator_count + prey_count)
evo -> evo : build_networks()

== Generation Loop (repeated until max_generations) ==
main -> evo : evaluate_generation(sim)
evo -> sim : reset()
evo -> sim : initialize()

alt GPU path enabled
  evo -> gpu : upload_network_data(GpuNetworkData)
end

loop t = 0 .. generation_ticks-1

  alt CPU path
    loop i = 0 .. num_agents-1
      evo -> sim : get_sensors(i)
      sim --> evo : SensorInput
      evo -> nn : activate(inputs)
      nn --> evo : outputs[2]
      evo -> sim : apply_action(i, direction, dt)
    end
  else GPU path
    evo -> gpu : pack_inputs(flat_inputs)
    evo -> gpu : batch_neural_inference()
    note right: CUDA kernel: one thread per agent
    evo -> gpu : unpack_outputs(flat_out)
    loop i = 0 .. num_agents-1
      evo -> sim : apply_action(i, direction, dt)
    end
  end

  evo -> sim : tick(dt)
  evo -> log : [tick_callback] log_tick(gen, t, agents)

end

evo -> evo : compute_fitness(sim)

alt GPU path enabled
  evo -> gpu : pack_agent_stats(stats)
  evo -> gpu : batch_fitness_eval(weights)
  evo -> gpu : unpack_fitness(fitness_out)
end

main -> log : log_generation(metrics)
main -> log : log_best_genome(gen, genome)
main -> log : log_species(gen, species)

== Evolution Step ==
main -> evo : evolve()
evo -> evo : speciate()
evo -> evo : remove_stagnant_species()
evo -> evo : reproduce() : crossover + mutate
evo -> evo : tracker_.reset_generation()
evo -> evo : build_networks()

@enduml
