@startuml gpu_classes
skinparam classAttributeIconSize 0
skinparam classBorderColor #2255AA
skinparam classBackgroundColor #EEF4FF
skinparam ArrowColor #444444
skinparam shadowing false
skinparam defaultFontSize 11

class GpuNetDesc <<struct>> {
  + num_nodes : int
  + num_eval : int
  + num_inputs : int
  + num_outputs : int
  + node_off : int
  + eval_off : int
  + conn_off : int
  + out_off : int
}

class GpuAgentStats <<struct>> {
  + age_ratio : float
  + kills_or_food : float
  + energy_ratio : float
  + alive_bonus : float
  + dist_ratio : float
  + complexity : float
}

class GpuFitnessWeights <<struct>> {
  + survival_w : float
  + kill_w : float
  + energy_w : float
  + dist_w : float
  + complexity_w : float
}

class GpuNetworkData <<struct>> {
  + descs : vector<GpuNetDesc>
  + node_types : vector<uint8_t>
  + eval_order : vector<int>
  + conn_ptr : vector<int>
  + in_count : vector<int>
  + conn_from : vector<int>
  + conn_w : vector<float>
  + out_indices : vector<int>
  + activation_fn_id : int
}

class GpuBatch {
  - d_descs_ : GpuNetDesc*
  - d_inputs_ : float*
  - d_outputs_ : float*
  - d_stats_ : GpuAgentStats*
  - d_fitness_ : float*
  - d_node_vals_ : float*
  - d_node_types_ : uint8_t*
  - d_eval_order_ : int*
  - d_conn_ptr_ : int*
  - d_in_count_ : int*
  - d_conn_from_ : int*
  - d_conn_w_ : float*
  - d_out_indices_ : int*
  - num_agents_ : int
  - num_inputs_ : int
  - num_outputs_ : int
  - activation_fn_id_ : int
  --
  + GpuBatch(num_agents, num_inputs, num_outputs)
  + ~GpuBatch()
  + upload_network_data(data: GpuNetworkData) : void
  + pack_inputs(flat_inputs: vector<float>) : void
  + unpack_outputs(flat_out: vector<float>&) : void
  + pack_agent_stats(stats: vector<GpuAgentStats>) : void
  + unpack_fitness(fitness_out: vector<float>&) : void
  + d_descs() : const GpuNetDesc*
  + d_node_vals() : float*
  + num_agents() : int
  + num_inputs() : int
  + num_outputs() : int
  + activation_fn_id() : int
}

note top of GpuBatch
  Kernels (free functions):
  batch_neural_inference(batch)
  batch_fitness_eval(batch, weights)
end note

GpuBatch ..> GpuNetworkData : upload_network_data
GpuBatch ..> GpuAgentStats : pack_agent_stats
GpuBatch ..> GpuFitnessWeights : batch_fitness_eval
GpuNetworkData *-- GpuNetDesc

@enduml
